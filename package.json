{
  "name": "sw-mesh-viewer",
  "version": "0.2.0",
  "description": "Stormworks mesh parser and Three.js viewer utilities.",
  "homepage": "https://github.com/Teinishi/sw-mesh-viewer#readme",
  "license": "MIT",
  "author": "Teinishi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teinishi/sw-mesh-viewer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./parser": "./dist/parser.mjs",
    "./viewer": "./dist/viewer.mjs",
    "./vue": "./dist/vue.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "npm run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "docs": "typedoc --entryPointStrategy Expand ./src"
  },
  "peerDependencies": {
    "three": "^0.185.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
